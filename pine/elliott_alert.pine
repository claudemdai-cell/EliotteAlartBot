// Elliott Alert Bot — Pine Script v5
// TradingView → Flask server via webhook
//
// INSTRUCCIONES:
// 1. Pegar este script en TradingView (Pine Editor)
// 2. Configurar los niveles Elliott manualmente (wave_start, wave_end)
// 3. En "Create Alert" → seleccionar condición → URL del webhook → body JSON
// 4. Usar el JSON del "Webhook Message" de abajo

//@version=5
indicator("Elliott Alert Bot — 5 Layers", overlay=true)

// ─── INPUTS ────────────────────────────────────────────────────────────────
grp = "Elliott Wave Levels"
wave_start = input.float(0.0,  title="Wave Start (inicio onda)",  group=grp)
wave_end   = input.float(0.0,  title="Wave End (fin onda)",        group=grp)
stop_price = input.float(0.0,  title="Stop Loss",                  group=grp)
target_price = input.float(0.0, title="Target",                   group=grp)
in_elliott_zone = input.bool(false, title="Estoy en zona Elliott", group=grp)

// ─── INDICADORES ────────────────────────────────────────────────────────────
rsi_len  = input.int(14, title="RSI Length")
ema_len  = input.int(21, title="EMA Length")
vol_fast = input.int(5,  title="Volume Fast MA")
vol_slow = input.int(20, title="Volume Slow MA")

rsi_val   = ta.rsi(close, rsi_len)
ema21     = ta.ema(close, ema_len)
vol_avg5  = ta.sma(volume, vol_fast)
vol_avg20 = ta.sma(volume, vol_slow)

// ─── CÁLCULO DE CAPAS ────────────────────────────────────────────────────────
rango    = math.abs(wave_end - wave_start)
fib_50   = wave_end - rango * 0.500
fib_618  = wave_end - rango * 0.618
fib_low  = math.min(fib_50, fib_618)
fib_high = math.max(fib_50, fib_618)

c1 = in_elliott_zone
c2 = close >= fib_low and close <= fib_high
c3 = vol_avg5 < vol_avg20
c4 = rsi_val < 40
c5 = close > open

score = (c1 ? 1 : 0) + (c2 ? 1 : 0) + (c3 ? 1 : 0) + (c4 ? 1 : 0) + (c5 ? 1 : 0)

// ─── VISUALIZACIÓN ──────────────────────────────────────────────────────────
// Zona dorada Fibonacci
fib_zone = wave_start != 0 and wave_end != 0
bgcolor(fib_zone and close >= fib_low and close <= fib_high ? color.new(color.yellow, 85) : na)

// EMA 21
plot(ema21, color=color.blue, linewidth=2, title="EMA 21")

// Niveles Fibonacci
plot(wave_start != 0 ? fib_50  : na, color=color.orange, style=plot.style_line, title="Fib 50%")
plot(wave_start != 0 ? fib_618 : na, color=color.red,    style=plot.style_line, title="Fib 61.8%")

// Score label
if barstate.islast and wave_start != 0
    label_color = score >= 4 ? color.green : score == 3 ? color.orange : color.red
    label.new(bar_index, high * 1.002,
              "SCORE: " + str.tostring(score) + "/5\n" +
              "C1 Elliott: " + (c1 ? "✓" : "✗") + "\n" +
              "C2 Fib 50-61.8: " + (c2 ? "✓" : "✗") + "\n" +
              "C3 Volumen: " + (c3 ? "✓" : "✗") + "\n" +
              "C4 RSI<40: " + (c4 ? "✓" : "✗") + "\n" +
              "C5 Vela: " + (c5 ? "✓" : "✗"),
              color=label_color, textcolor=color.white, style=label.style_label_down, size=size.normal)

// ─── CONDICIÓN DE ALERTA ─────────────────────────────────────────────────────
alert_condition = score >= 4
alertcondition(alert_condition, title="Elliott 4/5 Layers", message="Elliott setup: {{ticker}} score={{plot_0}}")

// ─── WEBHOOK JSON TEMPLATE ───────────────────────────────────────────────────
// Copiar esto en "Message" al crear la alerta en TradingView:
//
// {
//   "asset": "{{ticker}}",
//   "price": {{close}},
//   "open_4h": {{open}},
//   "close_4h": {{close}},
//   "high_4h": {{high}},
//   "low_4h": {{low}},
//   "rsi_4h": {{plot_0}},
//   "volume_avg5": {{plot_1}},
//   "volume_avg20": {{plot_2}},
//   "ema21_4h": {{plot_3}},
//   "in_elliott_zone": true,
//   "wave_start": PONER_MANUALMENTE,
//   "wave_end": PONER_MANUALMENTE,
//   "stop": PONER_MANUALMENTE,
//   "target": PONER_MANUALMENTE
// }
//
// URL del webhook: https://TU-SERVIDOR/webhook?secret=elliott2026

// Plots para el webhook (orden importante)
plot(rsi_val,   title="RSI",        display=display.data_window)
plot(vol_avg5,  title="Vol Avg5",   display=display.data_window)
plot(vol_avg20, title="Vol Avg20",  display=display.data_window)
plot(ema21,     title="EMA21 Data", display=display.data_window)
